#ifndef _LIBCUDACXX___ASSERT
#define _LIBCUDACXX___ASSERT

#include <cuda/std/detail/__config>

#if defined(_CCCL_IMPLICIT_SYSTEM_HEADER_GCC)
#  pragma GCC system_header
#elif defined(_CCCL_IMPLICIT_SYSTEM_HEADER_CLANG)
#  pragma clang system_header
#elif defined(_CCCL_IMPLICIT_SYSTEM_HEADER_MSVC)
#  pragma system_header
#endif // no system header

#include <cuda/std/detail/libcxx/include/__verbose_abort>

// This is for backwards compatibility with code that might have been enabling
// assertions through the Debug mode previously.
// TODO: In LLVM 16, make it an error to define _LIBCUDACXX_DEBUG
#ifdef _LIBCUDACXX_DEBUG
#  ifndef _LIBCUDACXX_ENABLE_ASSERTIONS
#    define _LIBCUDACXX_ENABLE_ASSERTIONS 1
#  endif // _LIBCUDACXX_ENABLE_ASSERTIONS
#endif // _LIBCUDACXX_DEBUG

// Automatically enable assertions when the debug mode is enabled.
#ifdef _LIBCUDACXX_ENABLE_DEBUG_MODE
#  ifndef _LIBCUDACXX_ENABLE_ASSERTIONS
#    define _LIBCUDACXX_ENABLE_ASSERTIONS 1
#  endif // !_LIBCUDACXX_ENABLE_ASSERTIONS
#endif // _LIBCUDACXX_ENABLE_DEBUG_MODE

#ifndef _LIBCUDACXX_ENABLE_ASSERTIONS
#  define _LIBCUDACXX_ENABLE_ASSERTIONS _LIBCUDACXX_ENABLE_ASSERTIONS_DEFAULT
#endif // !_LIBCUDACXX_ENABLE_ASSERTIONS

#if _LIBCUDACXX_ENABLE_ASSERTIONS != 0 && _LIBCUDACXX_ENABLE_ASSERTIONS != 1
#  error "_LIBCUDACXX_ENABLE_ASSERTIONS must be set to 0 or 1"
#endif
#if _LIBCUDACXX_ENABLE_ASSERTIONS
#  define _LIBCUDACXX_ENABLE_HARDENED_MODE 1
#endif // _LIBCUDACXX_ENABLE_ASSERTIONS

// Enables the hardened mode which consists of all checks intended to be used in production. Hardened mode prioritizes
// security-critical checks that can be done with relatively little overhead in constant time. Mutually exclusive with
// `_LIBCUDACXX_ENABLE_DEBUG_MODE`.
//
// #define _LIBCUDACXX_ENABLE_HARDENED_MODE 1

// Enables the debug mode which contains all the checks from the hardened mode and additionally more expensive checks
// that may affect the complexity of algorithms. The debug mode is intended to be used for testing, not in production.
// Mutually exclusive with `_LIBCUDACXX_ENABLE_HARDENED_MODE`.
//
// #define _LIBCUDACXX_ENABLE_DEBUG_MODE 1

// Inside the library, assertions are categorized so they can be cherry-picked based on the chosen hardening mode. These
// macros are only for internal use -- users should only pick one of the high-level hardening modes described above.
//
// - `_LIBCUDACXX_ASSERT_VALID_INPUT_RANGE` -- checks that ranges (whether expressed as an iterator pair, an iterator
// and
//   a sentinel, an iterator and a count, or a `std::range`) given as input to library functions are valid:
//   - the sentinel is reachable from the begin iterator;
//   - TODO(hardening): both iterators refer to the same container.
//
// - `_LIBCUDACXX_ASSERT_VALID_ELEMENT_ACCESS` -- checks that any attempts to access a container element, whether
// through
//   the container object or through an iterator, are valid and do not attempt to go out of bounds or otherwise access
//   a non-existent element. For iterator checks to work, bounded iterators must be enabled in the ABI. Types like
//   `optional` and `function` are considered one-element containers for the purposes of this check.
//
// - `_LIBCUDACXX_ASSERT_NON_OVERLAPPING_RANGES` -- for functions that take several ranges as arguments, checks that the
//   given ranges do not overlap.
//
// - `_LIBCUDACXX_ASSERT_COMPATIBLE_ALLOCATOR` -- checks any operations that exchange nodes between containers to make
// sure
//   the containers have compatible allocators.
//
// - `_LIBCUDACXX_ASSERT_INTERNAL` -- checks that internal invariants of the library hold. These assertions don't depend
// on
//   user input.
//
// - `_LIBCUDACXX_ASSERT_UNCATEGORIZED` -- for assertions that haven't been properly classified yet.

#ifndef _LIBCUDACXX_ENABLE_HARDENED_MODE
#  define _LIBCUDACXX_ENABLE_HARDENED_MODE _LIBCUDACXX_ENABLE_HARDENED_MODE_DEFAULT
#endif // !_LIBCUDACXX_ENABLE_HARDENED_MODE
#if _LIBCUDACXX_ENABLE_HARDENED_MODE != 0 && _LIBCUDACXX_ENABLE_HARDENED_MODE != 1
#  error "_LIBCUDACXX_ENABLE_HARDENED_MODE must be set to 0 or 1."
#endif

#ifndef _LIBCUDACXX_ENABLE_DEBUG_MODE
#  define _LIBCUDACXX_ENABLE_DEBUG_MODE _LIBCUDACXX_ENABLE_DEBUG_MODE_DEFAULT
#endif // !_LIBCUDACXX_ENABLE_DEBUG_MODE

#if _LIBCUDACXX_ENABLE_DEBUG_MODE != 0 && _LIBCUDACXX_ENABLE_DEBUG_MODE != 1
#  error "_LIBCUDACXX_ENABLE_DEBUG_MODE must be set to 0 or 1."
#endif

#if _LIBCUDACXX_ENABLE_HARDENED_MODE && _LIBCUDACXX_ENABLE_DEBUG_MODE
#  error "Only one of _LIBCUDACXX_ENABLE_HARDENED_MODE and _LIBCUDACXX_ENABLE_DEBUG_MODE can be enabled."
#endif

// Hardened mode checks.

#if _LIBCUDACXX_ENABLE_HARDENED_MODE

// Enabled checks.
#  define _LIBCUDACXX_ASSERT_VALID_INPUT_RANGE(expression, message)    _LIBCUDACXX_ASSERT(expression, message)
#  define _LIBCUDACXX_ASSERT_VALID_ELEMENT_ACCESS(expression, message) _LIBCUDACXX_ASSERT(expression, message)
// Disabled checks.
// Overlapping ranges will make algorithms produce incorrect results but don't directly lead to a security
// vulnerability.
#  define _LIBCUDACXX_ASSERT_NON_OVERLAPPING_RANGES(expression, message) _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_COMPATIBLE_ALLOCATOR(expression, message)   _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_INTERNAL(expression, message)               _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_UNCATEGORIZED(expression, message)          _LIBCUDACXX_ASSUME(expression)

// Debug mode checks.

#elif _LIBCUDACXX_ENABLE_DEBUG_MODE

// All checks enabled.
#  define _LIBCUDACXX_ASSERT_VALID_INPUT_RANGE(expression, message)      _LIBCUDACXX_ASSERT(expression, message)
#  define _LIBCUDACXX_ASSERT_VALID_ELEMENT_ACCESS(expression, message)   _LIBCUDACXX_ASSERT(expression, message)
#  define _LIBCUDACXX_ASSERT_NON_OVERLAPPING_RANGES(expression, message) _LIBCUDACXX_ASSERT(expression, message)
#  define _LIBCUDACXX_ASSERT_COMPATIBLE_ALLOCATOR(expression, message)   _LIBCUDACXX_ASSERT(expression, message)
#  define _LIBCUDACXX_ASSERT_INTERNAL(expression, message)               _LIBCUDACXX_ASSERT(expression, message)
#  define _LIBCUDACXX_ASSERT_UNCATEGORIZED(expression, message)          _LIBCUDACXX_ASSERT(expression, message)

// Disable all checks if hardening is not enabled.

#else

// All checks disabled.
#  define _LIBCUDACXX_ASSERT_VALID_INPUT_RANGE(expression, message)      _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_VALID_ELEMENT_ACCESS(expression, message)   _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_NON_OVERLAPPING_RANGES(expression, message) _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_COMPATIBLE_ALLOCATOR(expression, message)   _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_INTERNAL(expression, message)               _LIBCUDACXX_ASSUME(expression)
#  define _LIBCUDACXX_ASSERT_UNCATEGORIZED(expression, message)          _LIBCUDACXX_ASSUME(expression)

#endif // _LIBCUDACXX_ENABLE_HARDENED_MODE

#if _LIBCUDACXX_ENABLE_ASSERTIONS
#  define _LIBCUDACXX_ASSERT(expression, message)        \
    (_CCCL_DIAG_PUSH                                                            \
    _CCCL_DIAG_SUPPRESS_CLANG("-Wassume")                                       \
    __builtin_expect(static_cast<bool>(expression), 1) ?                        \
      (void)0 :                                                                 \
      ::_CUDA_VSTD::__libcpp_verbose_abort("%s:%d: assertion %s failed: %s", __FILE__, __LINE__, #expression, message)
    _CCCL_DIAG_POP)
#  define _LIBCUDACXX_ASSUME(expression)                                                                   \
    (_CCCL_DIAG_PUSH _CCCL_DIAG_SUPPRESS_CLANG("-Wassume") __builtin_assume(static_cast<bool>(expression)) \
       _CCCL_DIAG_POP)
#else
#  define _LIBCUDACXX_ASSERT(expression, message) ((void) 0)
#  define _LIBCUDACXX_ASSUME(expression)          ((void) 0)
#endif

#endif // _LIBCUDACXX___ASSERT
